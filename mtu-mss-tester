#!/usr/bin/env python3
import os
import sys
import socket
import struct
import select
import time

def compute_checksum(source_string):
    sum_val = 0
    count_to = (len(source_string) // 2) * 2
    count = 0
    while count < count_to:
        this_val = source_string[count + 1] * 256 + source_string[count]
        sum_val = sum_val + this_val
        sum_val = sum_val & 0xffffffff
        count = count + 2
    if count_to < len(source_string):
        sum_val = sum_val + source_string[len(source_string) - 1]
        sum_val = sum_val & 0xffffffff
    sum_val = (sum_val >> 16) + (sum_val & 0xffff)
    sum_val = sum_val + (sum_val >> 16)
    answer = ~sum_val
    answer = answer & 0xffff
    answer = answer >> 8 | (answer << 8 & 0xff00)
    return answer

def send_icmp_ping(sock, dest_addr, payload_size, seq_num):
    # ICMP header: type (8), code (0), checksum (0), id (process_id), sequence
    my_id = os.getpid() & 0xFFFF
    header = struct.pack("bbHHh", 8, 0, 0, my_id, seq_num)
    data = struct.pack("d", time.time()) + (b"Q" * (payload_size - 8))
    my_checksum = compute_checksum(header + data)
    
    # Pack header with real checksum
    header = struct.pack("bbHHh", 8, 0, socket.htons(my_checksum), my_id, seq_num)
    packet = header + data
    
    try:
        sock.sendto(packet, (dest_addr, 1))
        return True
    except OSError as e:
        # e.errno == 40 is EMSGSIZE on macOS
        if e.errno == 40 or "too long" in str(e).lower():
            return False
        raise

def receive_icmp_reply(sock, timeout=1.0):
    ready = select.select([sock], [], [], timeout)
    if ready[0] == []: # Timeout
        return False
    try:
        rec_packet, addr = sock.recvfrom(2048)
        return True
    except socket.timeout:
        return False
    except OSError:
        return False

def sweep_mtu(target_host, timeout=1.0):
    print(f"🔍 Sweeping Path MTU to {target_host}...")
    try:
        dest_addr = socket.gethostbyname(target_host)
    except socket.gaierror:
        print(f"❌ Cannot resolve host: {target_host}")
        return None

    # Create raw socket (needs sudo/admin)
    try:
        # On macOS raw sockets require root privileges
        raw_sock = socket.socket(socket.AF_INET, socket.SOCK_RAW, socket.IPPROTO_ICMP)
    except PermissionError:
        print("❌ Permission Denied: Raw sockets require root privileges.")
        print("💡 Please run the script using: sudo python3 tester.py <host>")
        sys.exit(1)
        
    # Set DF (Don't Fragment) bit
    # macOS IP_DONTFRAG constant is 28
    IP_DONTFRAG = 28
    raw_sock.setsockopt(socket.IPPROTO_IP, IP_DONTFRAG, 1)
    raw_sock.settimeout(timeout)

    low = 500
    high = 1500
    best_payload = 0
    seq_num = 1

    print(f"⚡️ Sweeping payload sizes [{low} to {high}]...")
    while low <= high:
        mid = (low + high) // 2
        
        # Try pinging 2 times to prevent random packet loss issues
        success = False
        for _ in range(2):
            if send_icmp_ping(raw_sock, dest_addr, mid, seq_num):
                seq_num += 1
                if receive_icmp_reply(raw_sock, timeout):
                    success = True
                    break
            time.sleep(0.02)
            
        if success:
            best_payload = mid
            low = mid + 1
        else:
            high = mid - 1
            
    raw_sock.close()
    
    if best_payload == 0:
        print("❌ Host did not respond to any MTU sweep packets.")
        return None
        
    # MTU = Payload + 8 (ICMP Header) + 20 (IPv4 Header)
    detected_mtu = best_payload + 8 + 20
    return detected_mtu

def validate_tcp_mss(target_host, port=80):
    print(f"🔗 Establishing TCP handshake to {target_host}:{port}...")
    try:
        # standard stream TCP socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(3.0)
        s.connect((target_host, port))
        
        # Read TCP_MAXSEG option (defined as 2 in standard sockets)
        TCP_MAXSEG = 2
        mss_val = s.getsockopt(socket.IPPROTO_TCP, TCP_MAXSEG)
        s.close()
        return mss_val
    except Exception as e:
        print(f"⚠️ TCP connection failed: {e}")
        return None

def main():
    if len(sys.argv) < 2:
        host = "8.8.8.8"
    else:
        host = sys.argv[1]
        
    port = 80
    if len(sys.argv) > 2:
        try:
            port = int(sys.argv[2])
        except ValueError:
            pass

    print("====================================================")
    print(" 🌐 Python MTU & TCP-MSS Tester Tool")
    print("====================================================")
    print(f"Target Host: {host}")
    print(f"TCP Port:    {port}")
    print("----------------------------------------------------")
    
    mtu = sweep_mtu(host)
    if not mtu:
        return
        
    print(f"\n✅ DETECTED PATH MTU: {mtu} bytes")
    
    mss = validate_tcp_mss(host, port)
    if mss:
        print(f"✅ NEGOTIATED TCP-MSS: {mss} bytes")
        
        calc_ipv4 = mtu - 40
        calc_ipv6 = mtu - 60
        
        print("\n📊 ANALYSIS REPORT:")
        print("----------------------------------------------------")
        print(f"• Detected Path MTU:  {mtu} bytes")
        print(f"• Negotiated TCP-MSS: {mss} bytes")
        print(f"• Expected IPv4 MSS:  {calc_ipv4} bytes (MTU-40)")
        print(f"• Expected IPv6 MSS:  {calc_ipv6} bytes (MTU-60)")
        print("----------------------------------------------------")
        
        if mss == calc_ipv4:
            print("✨ Your connection is using standard optimal IPv4 MSS limits!")
        elif mss < calc_ipv4:
            print("⚠️ Negotiated TCP-MSS is smaller than expected.")
            print("   This is clear evidence of active TCP-MSS clamping by intermediate routers/VPNs!")
        else:
            print("✨ Optimized localized/jumbo frames route.")
    else:
        print("\n❌ Could not establish TCP connection to retrieve negotiated TCP-MSS.")
    print("====================================================")

if __name__ == "__main__":
    main()
